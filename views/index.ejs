<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/styles.css">
</head>

<body>
    <h1>
        <%= title %>
    </h1>
    <% if (data) { %>
        <ul>
            <% data.forEach(item=> { %>
                <li>
                    <%= item %>
                </li>
                <% }) %>
        </ul>
        <% } else { %>
            <p>Aucune donnée à afficher.</p>
            <% } %>
</body>

</html>